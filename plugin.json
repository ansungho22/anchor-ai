{
  "name": "anchor-ai-harness",
  "displayName": "Anchor AI Harness",
  "description": "Plug-and-play multi-agent development environment",
  "version": "1.0",
  "workspace": {
    "name": "multi-agent-harness",
    "description": "Plug-and-play multi-agent development environment",
    "strict_mode": true
  },
  "permissions": {
    "file_read": ["*"],
    "file_write": ["*"],
    "blocked_paths": [
      ".agents/**",
      "docs/templates/**"
    ],
    "execute_commands": true
  },
  "default_model": "gemini-3.1-pro",
  "hooks": {
    "post_task": "./hooks/post-task.sh"
  }
}
